---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title       = 'Humendra Pun — Data Analyst',
  description = 'MSc Software Engineering graduate specialising in data analysis, Python, SQL, and Power BI.',
} = Astro.props;

const siteUrl = 'https://humendra-portfolio.vercel.app';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Humendra Pun" />
  <link rel="canonical" href={siteUrl} />

  <!-- Favicon (emoji fallback — replace with /favicon.ico for a real one) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📊</text></svg>" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={siteUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name"   content="Humendra Pun" />
  <!-- Add og:image by dropping a 1200x630 image into public/ and updating the path below -->
  <!-- <meta property="og:image" content={`${siteUrl}/og-image.png`} /> -->

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />

  <script>
    // Scroll-reveal for all .fade-up elements
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
  </script>
</body>
</html>
