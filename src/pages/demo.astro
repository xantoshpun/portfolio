---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="demo-wrapper">
    <div style="text-align: center; padding: 4rem 2rem 2rem;">
      <h1 style="color: var(--cyan); font-size: 2rem;">Avatar Hover Collection (10 Styles)</h1>
      <p style="color: var(--muted); margin-top: 1rem;">Hover over each portrait to see the interactive effect in action.</p>
    </div>

    <div class="demo-grid">
      
      <!-- Option 1: 3D Holographic Tilt -->
      <div class="demo-col">
        <h2 class="demo-title">1. 3D Holographic</h2>
        <p class="demo-desc">Tilts dynamically following your mouse.</p>
        <div class="avatar-base tilt-card" id="tilt-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 2: Tech Scanner -->
      <div class="demo-col">
        <h2 class="demo-title">2. Tech Scanner</h2>
        <p class="demo-desc">Neon laser sweeps down overriding colors.</p>
        <div class="avatar-base scanner-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 3: Neon Power Surge -->
      <div class="demo-col">
        <h2 class="demo-title">3. Power Surge</h2>
        <p class="demo-desc">Intense neon border glow expansion.</p>
        <div class="avatar-base surge-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 4: Cyber Glitch -->
      <div class="demo-col">
        <h2 class="demo-title">4. Cyber Glitch</h2>
        <p class="demo-desc">Rapid jitter and RGB channel splitting.</p>
        <div class="avatar-base glitch-card" data-text="ERROR">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 5: 3D Card Flip -->
      <div class="demo-col">
        <h2 class="demo-title">5. 3D Card Flip</h2>
        <p class="demo-desc">Flips 180° revealing your tech stack on back.</p>
        <div class="flip-card-container">
          <div class="flip-card-inner">
            <div class="avatar-base flip-card-front">
              <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
            </div>
            <div class="avatar-base flip-card-back">
              <div class="back-text">
                <span style="color:var(--cyan)">&lt;Stack/&gt;</span><br/><br/>
                Python<br/>Power BI<br/>SQL<br/>Astro
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Option 6: Thermal X-Ray -->
      <div class="demo-col">
        <h2 class="demo-title">6. Thermal X-Ray</h2>
        <p class="demo-desc">Inverts contrast to look like night-vision.</p>
        <div class="avatar-base xray-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 7: Levitation Float -->
      <div class="demo-col">
        <h2 class="demo-title">7. Levitation</h2>
        <p class="demo-desc">Defies gravity with huge soft drop shadow.</p>
        <div class="avatar-base float-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 8: Sonar Pings -->
      <div class="demo-col">
        <h2 class="demo-title">8. Sonar Pings</h2>
        <p class="demo-desc">Radiates radar ripples outward continuously.</p>
        <div class="avatar-base sonar-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 9: Acrylic Glaze -->
      <div class="demo-col">
        <h2 class="demo-title">9. Acrylic Glaze</h2>
        <p class="demo-desc">Smooth diagonal glass glare sweeps across.</p>
        <div class="avatar-base glaze-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

      <!-- Option 10: Vintage CRT -->
      <div class="demo-col">
        <h2 class="demo-title">10. Vintage CRT</h2>
        <p class="demo-desc">Simulates a flickering old tube monitor.</p>
        <div class="avatar-base crt-card">
          <img src="/pics/2.png" alt="Humendra Pun" class="avatar-img" />
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  .demo-wrapper { min-height: 100vh; padding-bottom: 5rem; }
  .demo-grid {
    display: flex; gap: 4rem; justify-content: center; flex-wrap: wrap; padding: 2rem;
  }
  .demo-col {
    display: flex; flex-direction: column; align-items: center; text-align: center; width: 260px;
  }
  .demo-title { color: white; font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; margin-bottom: 0.5rem; }
  .demo-desc { color: var(--muted); font-size: 0.85rem; margin-bottom: 1.5rem; min-height: 2.5rem; }

  /* BASE AVATAR SHAPE */
  .avatar-base {
    width: 220px; height: 300px; flex-shrink: 0;
    border-radius: 24px;
    background: rgba(25,230,206,0.08);
    border: 2px solid rgba(25,230,206,0.35);
    display: flex; align-items: center; justify-content: center;
    position: relative;
    cursor: pointer;
  }
  .avatar-img {
    width: 100%; height: 100%; object-fit: cover; border-radius: 24px;
  }

  /* ── 1. TILT ── */
  .tilt-card { will-change: transform; transform-style: preserve-3d; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
  
  /* ── 2. SCANNER ── */
  .scanner-card { overflow: hidden; }
  .scanner-card::after {
    content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 3px;
    background: #00ffcc; box-shadow: 0 0 15px 5px rgba(0, 255, 204, 0.4); opacity: 0; transition: opacity 0.2s;
  }
  .scanner-card:hover::after { opacity: 1; animation: scan-line 1.5s linear infinite; }
  .scanner-card img { transition: filter 0.3s ease; }
  .scanner-card:hover img { filter: sepia(100%) hue-rotate(140deg) saturate(200%) contrast(110%); }
  @keyframes scan-line { 0% { top: -10%; } 100% { top: 110%; } }

  /* ── 3. SURGE ── */
  .surge-card { transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
  .surge-card::before {
    content: ''; position: absolute; inset: -4px; border: 2px solid rgba(25,230,206,0.12);
    border-radius: 28px; transition: all 0.4s ease; z-index: -1;
  }
  .surge-card:hover { transform: translateY(-8px) scale(1.05); }
  .surge-card:hover::before {
    border-color: var(--cyan);
    box-shadow: 0 0 30px rgba(25,230,206,0.6), inset 0 0 20px rgba(25,230,206,0.3); inset: -10px;
  }

  /* ── 4. GLITCH ── */
  .glitch-card:hover img { animation: glitch-anim 0.3s infinite linear alternate-reverse; }
  @keyframes glitch-anim {
    0% { clip-path: inset(20% 0 80% 0); transform: translate(-2px, 2px); filter: hue-rotate(90deg); }
    20% { clip-path: inset(60% 0 10% 0); transform: translate(2px, -2px); filter: hue-rotate(0deg); }
    40% { clip-path: inset(40% 0 50% 0); transform: translate(-2px, 0px); filter: hue-rotate(180deg); }
    60% { clip-path: inset(80% 0 5% 0); transform: translate(2px, 2px); filter: hue-rotate(90deg); }
    80% { clip-path: inset(10% 0 70% 0); transform: translate(-2px, -2px); filter: hue-rotate(0deg); }
    100% { clip-path: inset(30% 0 50% 0); transform: translate(2px, 0px); filter: hue-rotate(180deg); }
  }

  /* ── 5. FLIP ── */
  .flip-card-container { width: 220px; height: 300px; perspective: 1000px; cursor: pointer; }
  .flip-card-inner {
    position: relative; width: 100%; height: 100%; text-align: center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); transform-style: preserve-3d;
  }
  .flip-card-container:hover .flip-card-inner { transform: rotateY(180deg); }
  .flip-card-front, .flip-card-back {
    position: absolute; width: 100%; height: 100%; backface-visibility: hidden; top:0; left:0;
  }
  .flip-card-back {
    background: #060910; transform: rotateY(180deg);
    display: flex; align-items: center; justify-content: center;
  }
  .back-text { color: white; font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; line-height: 1.5; }

  /* ── 6. X-RAY ── */
  .xray-card img { transition: filter 0.5s ease; }
  .xray-card:hover img { filter: invert(1) hue-rotate(180deg) brightness(1.2) contrast(1.5); }

  /* ── 7. LEVITATION ── */
  .float-card { transition: transform 0.5s ease, box-shadow 0.5s ease; }
  .float-card:hover { 
    transform: translateY(-25px); 
    box-shadow: 0 40px 40px rgba(0,0,0,0.8), 0 20px 20px rgba(25,230,206,0.1); 
  }

  /* ── 8. SONAR ── */
  .sonar-card::before, .sonar-card::after {
    content: ''; position: absolute; top:0; left:0; width:100%; height:100%;
    border-radius: 24px; border: 2px solid var(--cyan);
    opacity: 0; z-index: -1;
  }
  .sonar-card:hover::before { animation: sonar 1.5s infinite linear; }
  .sonar-card:hover::after { animation: sonar 1.5s 0.75s infinite linear; }
  @keyframes sonar {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.3); opacity: 0; }
  }

  /* ── 9. GLAZE ── */
  .glaze-card { overflow: hidden; }
  .glaze-card::after {
    content:''; position: absolute; top:0; left:-150%; width: 100%; height: 100%;
    background: linear-gradient(105deg, transparent, rgba(255,255,255,0.4), transparent);
    transition: left 0.6s ease-in-out;
  }
  .glaze-card:hover::after { left: 150%; }

  /* ── 10. CRT ── */
  .crt-card { overflow: hidden; }
  .crt-card::after {
    content:''; position: absolute; top:0; left:0; width:100%; height:100%;
    background: repeating-linear-gradient(0deg, rgba(0,0,0,0.15) 0px, rgba(0,0,0,0.15) 1px, transparent 1px, transparent 2px);
    opacity: 0; transition: opacity 0.3s;
  }
  .crt-card:hover::after { opacity: 1; animation: crt-flicker 0.15s infinite; }
  .crt-card:hover img { filter: sepia(0.6) hue-rotate(120deg) saturate(3) brightness(0.8) contrast(1.5); }
  @keyframes crt-flicker {
    0% { opacity: 0.9; } 50% { opacity: 0.5; } 100% { opacity: 0.9; }
  }

</style>

<script>
  // Script for the Tilt Card logic
  const card = document.getElementById('tilt-card');
  if (card) {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotX = -((y - centerY) / centerY) * 15;
      const rotY = ((x - centerX) / centerX) * 15;
      card.style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) scale(1.05)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)`;
      card.style.transition = 'transform 0.5s ease';
    });
    card.addEventListener('mouseenter', () => {
      card.style.transition = 'transform 0.1s ease';
    });
  }
</script>
