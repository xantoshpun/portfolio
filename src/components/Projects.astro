---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const iconBg: Record<string, string> = {
  cyan:   'rgba(0,212,255,0.1)',
  purple: 'rgba(124,58,237,0.1)',
  green:  'rgba(16,185,129,0.1)',
};
---

<section id="projects">
  <div class="container">
    <div class="section-label">projects</div>
    <h2 class="section-title">Featured <span style="color: var(--cyan);">Work</span></h2>
    <p class="section-sub">
      Selected projects showcasing my data analysis and visualisation expertise.
      Click any card to see the full case study.
    </p>

    <div class="projects-grid fade-up">
      {projects.map(p => (
        <a href={`/projects/${p.slug}`} class="project-card">
          <div class="proj-header">
            <div class="proj-icon" style={`background:${iconBg[p.data.techColor]}`}>
              {p.data.icon}
            </div>
            <div class="proj-open-hint">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              View case study
            </div>
          </div>

          <div class="proj-body">
            <div class={`proj-tech ${p.data.techColor}`}>{p.data.tech}</div>
            <div class="proj-title">{p.data.title}</div>
            <p class="proj-summary">{p.data.summary}</p>
            <div class="proj-metrics">
              {p.data.metrics.map(m => <span class="metric">{m}</span>)}
            </div>
          </div>

          <div class="proj-tools">
            {p.data.tools.map(t => <span class="tool-tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  #projects { background: var(--bg2); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
  }

  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
    text-decoration: none; display: block;
    position: relative;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .project-card::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(0,212,255,0.03) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s;
  }
  .project-card:hover {
    border-color: rgba(0,212,255,0.3);
    transform: translateY(-5px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35), var(--glow);
  }
  .project-card:hover::before { opacity: 1; }

  .proj-header {
    padding: 1.75rem 1.75rem 0;
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 1rem;
  }
  .proj-icon {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
  }
  .proj-open-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; color: var(--muted);
    display: flex; align-items: center; gap: 0.4rem;
    margin-top: 0.5rem; transition: color 0.2s;
  }
  .project-card:hover .proj-open-hint { color: var(--cyan); }

  .proj-body { padding: 1.25rem 1.75rem 1.5rem; }
  .proj-tech {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 0.6rem;
  }
  .proj-tech.cyan   { color: var(--cyan); }
  .proj-tech.purple { color: #a78bfa; }
  .proj-title { font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.7rem; letter-spacing: -0.01em; }
  .proj-summary { color: var(--muted); font-size: 0.9rem; line-height: 1.75; margin-bottom: 1.2rem; }

  .proj-metrics { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .metric {
    background: rgba(16,185,129,0.08);
    border: 1px solid rgba(16,185,129,0.2);
    color: #34d399;
    padding: 0.28rem 0.7rem; border-radius: 6px;
    font-size: 0.75rem; font-family: 'JetBrains Mono', monospace;
  }

  .proj-tools {
    display: flex; flex-wrap: wrap; gap: 0.45rem;
    padding: 1.1rem 1.75rem;
    border-top: 1px solid var(--border);
  }
  .tool-tag {
    background: var(--bg3); color: var(--muted);
    padding: 0.25rem 0.6rem; border-radius: 5px;
    font-size: 0.72rem; font-family: 'JetBrains Mono', monospace;
  }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
