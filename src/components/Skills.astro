---
import skills from '../data/skills.json';

const iconBg: Record<string, string> = {
  cyan:   'rgba(0,212,255,0.1)',
  purple: 'rgba(124,58,237,0.1)',
  green:  'rgba(16,185,129,0.1)',
};
---

<section id="skills">
  <div class="container">
    <div class="section-label fade-left">skills</div>
    <h2 class="section-title fade-up">My <span class="shimmer-ready" style="color: var(--cyan);">Tech Stack</span></h2>
    <p class="section-sub fade-up">Tools and technologies I use to extract insights from data and build intelligent solutions.</p>

    <div class="skills-grid stagger-children">
      {skills.map(s => (
        <div class="skill-card">
          <div class="skill-card-head">
            <div class="skill-icon" style={`background:${iconBg[s.color]}`}>{s.icon}</div>
            <div class="skill-title">{s.title}</div>
          </div>
          <div class="skill-tags">
            {s.tags.map(t => <span class={`tag ${s.color}`}>{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  @keyframes glow-pulse {
    0%   { box-shadow: 0 0 0px rgba(25,230,206,0); }
    50%  { box-shadow: 0 0 22px rgba(25,230,206,0.2); }
    100% { box-shadow: 0 0 12px rgba(25,230,206,0.1); }
  }
  .skill-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px; padding: 1.6rem;
    transition: border-color 0.3s var(--ease-spring), transform 0.3s var(--ease-spring);
  }
  .skill-card:hover {
    border-color: rgba(25,230,206,0.3);
    transform: translateY(-4px);
    animation: glow-pulse 0.6s var(--ease-out) forwards;
  }
  .skill-card-head { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.1rem; }
  .skill-icon {
    width: 38px; height: 38px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center; font-size: 1.15rem;
  }
  .skill-title { font-size: 0.875rem; font-weight: 700; color: var(--text); letter-spacing: 0.02em; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .tag { cursor: default; }
  .tag.cyan:hover   { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(25,230,206,0.2); }
  .tag.purple:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(124,58,237,0.2); }
  .tag.green:hover  { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(16,185,129,0.2); }
</style>
