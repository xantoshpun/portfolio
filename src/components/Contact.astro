---
import meta from '../data/meta.json';

const links = [
  { href: `mailto:${meta.email}`,    icon: '✉️', bg: 'rgba(0,212,255,0.08)',   label: 'Email',     val: meta.email },
  { href: meta.social.linkedin,      icon: '💼', bg: 'rgba(10,102,194,0.12)',  label: 'LinkedIn',  val: meta.social.linkedin },
  { href: meta.social.github,        icon: '🐙', bg: 'rgba(255,255,255,0.06)', label: 'GitHub',    val: meta.social.github },
  { href: meta.social.instagram,     icon: '📷', bg: 'rgba(225,48,108,0.08)', label: 'Instagram',  val: meta.social.instagram },
];
---

<section id="contact">
  <div class="container">
    <div class="section-label">contact</div>
    <h2 class="section-title">Let's <span style="color: var(--cyan);">Connect</span></h2>
    <p class="section-sub">Open to data analyst roles, freelance projects, and collaboration. Drop me a message.</p>

    <div class="contact-grid fade-up">

      <!-- Info side -->
      <div>
        <h3 class="contact-info-title">Get in touch</h3>
        <p class="contact-info-text">
          I'm always open to discussing data projects, collaboration opportunities,
          or just chatting about the latest in data and ML.
        </p>
        <div class="contact-links">
          {links.map(l => (
            <a href={l.href} target="_blank" rel="noopener" class="contact-link">
              <div class="contact-link-icon" style={`background:${l.bg}`}>{l.icon}</div>
              <div>
                <div class="contact-link-label">{l.label}</div>
                <div class="contact-link-val">{l.val}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Form side -->
      <form class="contact-form" action="https://formspree.io/f/xbdpbrjg" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="f-name">Name</label>
            <input id="f-name" type="text" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="f-email">Email</label>
            <input id="f-email" type="email" name="email" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="f-subject">Subject</label>
          <input id="f-subject" type="text" name="subject" placeholder="What's this about?" />
        </div>
        <div class="form-group">
          <label for="f-msg">Message</label>
          <textarea id="f-msg" name="message" placeholder="Tell me more..." required></textarea>
        </div>
        <button type="submit" class="form-submit">Send Message →</button>
      </form>

    </div>
  </div>
</section>

<style>
  #contact { background: var(--bg2); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem; align-items: start;
  }
  .contact-info-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.85rem; }
  .contact-info-text  { color: var(--muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 2rem; }
  .contact-links { display: flex; flex-direction: column; gap: 0.6rem; }
  .contact-link {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.8rem 1rem; border-radius: 10px;
    border: 1px solid transparent;
    text-decoration: none; color: var(--muted); font-size: 0.88rem;
    transition: all 0.22s;
  }
  .contact-link:hover { border-color: var(--border); background: var(--card); color: var(--text); }
  .contact-link-icon {
    width: 36px; height: 36px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }
  .contact-link-label { font-size: 0.72rem; color: var(--muted); }
  .contact-link-val   { font-size: 0.85rem; font-weight: 500; }

  /* form */
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.78rem; color: var(--muted); font-weight: 500; letter-spacing: 0.03em; }
  .form-group input,
  .form-group textarea {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.75rem 1rem;
    color: var(--text); font-size: 0.9rem;
    font-family: 'Inter', sans-serif; outline: none; resize: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: rgba(0,212,255,0.4);
    box-shadow: 0 0 0 3px rgba(0,212,255,0.06);
  }
  .form-group textarea { min-height: 130px; }
  .form-submit {
    background: var(--cyan); color: var(--bg);
    border: none; padding: 0.85rem 2rem;
    border-radius: 8px; font-weight: 700; font-size: 0.9rem;
    cursor: pointer; transition: all 0.25s;
    letter-spacing: 0.02em; align-self: flex-start;
    box-shadow: 0 0 20px rgba(0,212,255,0.25);
  }
  .form-submit:hover { transform: translateY(-2px); box-shadow: 0 0 35px rgba(0,212,255,0.4); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
