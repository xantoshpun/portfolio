---
import meta from '../data/meta.json';


//dont change this links value
const links = [
  {
    href: `mailto:${meta.email}`, label: 'Email', val: meta.email,
    bg: 'rgba(25,230,206,0.08)', color: 'var(--cyan)',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    href: meta.social.linkedin, label: 'LinkedIn', val: meta.social.linkedin,
    bg: 'rgba(10,102,194,0.12)', color: '#5b9bd5',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    href: meta.social.github, label: 'GitHub', val: meta.social.github,
    bg: 'rgba(255,255,255,0.06)', color: '#e2e8f0',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
  },
  {
    href: meta.social.kaggle, label: 'Kaggle', val: 'kaggle.com/xantoshpun',
    bg: 'rgba(25,230,206,0.08)', color: 'var(--cyan)',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.334z"/></svg>`,
  },
];
---

<section id="contact">
  <div class="container">
    <div class="section-label fade-left">contact</div>
    <h2 class="section-title fade-up">Let's <span class="shimmer-ready" style="color: var(--cyan);">Connect</span></h2>
    <p class="section-sub fade-up">Open to data analyst roles, freelance projects, and collaboration. Drop me a message.</p>

    <div class="contact-grid fade-up">

      <!-- Info side -->
      <div>
        <h3 class="contact-info-title">Get in touch</h3>
        <p class="contact-info-text">
          I'm always open to discussing data projects, collaboration opportunities,
          or just chatting about the latest in data and ML.
        </p>
        <div class="contact-links">
          {links.map(l => (
            <a href={l.href} target="_blank" rel="noopener" class="contact-link">
              <div class="contact-link-icon" style={`background:${l.bg}; color:${l.color}`} set:html={l.icon}></div>
              <div>
                <div class="contact-link-label">{l.label}</div>
                <div class="contact-link-val">{l.val}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Form side -->
      <div class="form-wrap">
        <form id="contact-form" class="contact-form" action="https://formspree.io/f/xbdpbrjg" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="f-name">Name</label>
              <input id="f-name" type="text" name="name" placeholder="Your name" required />
              <span class="field-error" id="err-name">Please enter your name (min 2 characters)</span>
            </div>
            <div class="form-group">
              <label for="f-email">Email</label>
              <input id="f-email" type="email" name="email" placeholder="your@email.com" required />
              <span class="field-error" id="err-email">Please enter a valid email address</span>
            </div>
          </div>
          <div class="form-group">
            <label for="f-subject">Subject</label>
            <input id="f-subject" type="text" name="subject" placeholder="What's this about?" />
          </div>
          <div class="form-group">
            <label for="f-msg">Message</label>
            <textarea id="f-msg" name="message" placeholder="Tell me more..." required></textarea>
            <span class="field-error" id="err-msg">Please enter a message (min 10 characters)</span>
          </div>
          <button type="submit" class="form-submit" id="form-btn">Send Message →</button>
        </form>

        <!-- Success message -->
        <div id="form-success" class="form-feedback success" aria-live="polite">
          <span class="feedback-icon">✓</span>
          <div>
            <div class="feedback-title">Message sent!</div>
            <div class="feedback-sub">Thanks for reaching out — I'll get back to you soon.</div>
          </div>
        </div>

        <!-- Error message -->
        <div id="form-error" class="form-feedback error" aria-live="polite">
          <span class="feedback-icon">✕</span>
          <div>
            <div class="feedback-title">Something went wrong</div>
            <div class="feedback-sub">Please try again or email me directly.</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #contact { background: var(--bg2); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem; align-items: start;
  }
  .contact-info-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.85rem; }
  .contact-info-text  { color: var(--muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 2rem; }
  .contact-links { display: flex; flex-direction: column; gap: 0.6rem; }
  .contact-link {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.8rem 1rem; border-radius: 10px;
    border: 1px solid transparent;
    text-decoration: none; color: var(--muted); font-size: 0.88rem;
    transition: all 0.22s;
    min-width: 0;
    min-height: 44px;
  }
  .contact-link:hover { border-color: var(--border); background: var(--card); color: var(--text); }
  .contact-link-icon {
    width: 38px; height: 38px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .contact-link-icon :global(svg) { display: block; }
  .contact-link-label { font-size: 0.72rem; color: var(--muted); }
  .contact-link-val   {
    font-size: 0.85rem; font-weight: 500;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  /* form */
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.78rem; color: var(--muted); font-weight: 500; letter-spacing: 0.03em; }
  .form-group input,
  .form-group textarea {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.75rem 1rem;
    color: var(--text); font-size: 0.9rem;
    font-family: 'Inter', sans-serif; outline: none; resize: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: rgba(0,212,255,0.4);
    box-shadow: 0 0 0 3px rgba(0,212,255,0.06);
  }
  .form-group textarea { min-height: 130px; }
  .form-submit {
    background: var(--cyan); color: var(--bg);
    border: none; padding: 0.85rem 2rem;
    border-radius: 8px; font-weight: 700; font-size: 0.9rem;
    cursor: pointer; transition: all 0.25s;
    letter-spacing: 0.02em; align-self: flex-start;
    box-shadow: 0 0 20px rgba(0,212,255,0.25);
  }
  .form-submit:hover { transform: translateY(-2px); box-shadow: 0 0 35px rgba(25,230,206,0.4); }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  /* Feedback messages */
  .form-feedback {
    display: none; align-items: center; gap: 1rem;
    padding: 1.1rem 1.25rem; border-radius: 10px;
    margin-top: 1rem;
  }
  .form-feedback.visible { display: flex; }
  .form-feedback.success { background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.25); }
  .form-feedback.error   { background: rgba(239,68,68,0.08);  border: 1px solid rgba(239,68,68,0.25); }
  .feedback-icon {
    font-size: 1.2rem; font-weight: 700; flex-shrink: 0;
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .form-feedback.success .feedback-icon { background: rgba(16,185,129,0.15); color: #34d399; }
  .form-feedback.error   .feedback-icon { background: rgba(239,68,68,0.15);  color: #f87171; }
  .feedback-title { font-size: 0.9rem; font-weight: 700; color: var(--text); }
  .feedback-sub   { font-size: 0.8rem; color: var(--muted); margin-top: 0.15rem; }

  .field-error {
    color: #ef4444;
    font-size: 0.73rem;
    margin-top: 0.25rem;
    display: none;
  }
  .field-error.visible { display: block; }
  input.invalid, textarea.invalid {
    border-color: rgba(239,68,68,0.5);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .form-wrap { width: 100%; }
    .contact-form { gap: 0.85rem; }
    .form-group input,
    .form-group textarea {
      padding: 0.85rem 0.9rem;
      font-size: 1rem; /* prevent iOS zoom on focus */
    }
    .form-group textarea { min-height: 110px; }
    .form-submit {
      width: 100%;
      align-self: stretch;
      padding: 1rem;
      font-size: 1rem;
      text-align: center;
    }
    .form-feedback { padding: 0.9rem 1rem; }
  }
</style>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const btn     = document.getElementById('form-btn')     as HTMLButtonElement;
  const success = document.getElementById('form-success');
  const error   = document.getElementById('form-error');

  // Real-time validation
  function validateField(input: HTMLInputElement | HTMLTextAreaElement, errorId: string, checkFn: (v: string) => boolean) {
    const err = document.getElementById(errorId);
    let touched = false;
    input.addEventListener('focus', () => { touched = true; });
    input.addEventListener('blur', () => {
      if (!touched) return;
      const isValid = checkFn(input.value.trim());
      input.classList.toggle('invalid', !isValid);
      err?.classList.toggle('visible', !isValid);
    });
    input.addEventListener('input', () => {
      if (input.classList.contains('invalid')) {
        const isValid = checkFn(input.value.trim());
        input.classList.toggle('invalid', !isValid);
        err?.classList.toggle('visible', !isValid);
      }
    });
  }

  const nameInput  = document.getElementById('f-name') as HTMLInputElement;
  const emailInput = document.getElementById('f-email') as HTMLInputElement;
  const msgInput   = document.getElementById('f-msg') as HTMLTextAreaElement;

  if (nameInput)  validateField(nameInput,  'err-name',  v => v.length >= 2);
  if (emailInput) validateField(emailInput, 'err-email', v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v));
  if (msgInput)   validateField(msgInput,   'err-msg',   v => v.length >= 10);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        form.reset();
        form.style.display = 'none';
        success?.classList.add('visible');
      } else {
        throw new Error('Failed');
      }
    } catch {
      error?.classList.add('visible');
      btn.disabled = false;
      btn.textContent = 'Send Message →';
    }
  });
</script>
